{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Example",
  "author": "Daniel Fry",
  "themes": [
    {
      "name": "Example",
      "appearance": "dark",
      "style": {
        "background": "#12101e",
        "border": "#262236",
        "border.variant": "#302c42",
        "border.focused": "#b8a0e080",
        "border.selected": "#b8a0e0",
        "border.transparent": "#00000000",
        "border.disabled": "#262236",

        "elevated_surface.background": "#1e1a2c",
        "surface.background": "#0e0c18",

        "element.background": "#1e1a2c",
        "element.hover": "#1e1a2c",
        "element.active": "#262236",
        "element.selected": "#262236",
        "element.disabled": "#1e1a2c80",

        "drop_target.background": "#26223680",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#1e1a2c",
        "ghost_element.active": "#262236",
        "ghost_element.selected": "#262236",
        "ghost_element.disabled": "#1e1a2c80",

        "text": "#d8d0e4",
        "text.muted": "#b0a8c4",
        "text.placeholder": "#8a8498",
        "text.disabled": "#8a849880",
        "text.accent": "#b8a0e0",

        "icon": "#b0a8c4",
        "icon.muted": "#8a8498",
        "icon.disabled": "#8a849880",
        "icon.placeholder": "#8a8498",
        "icon.accent": "#b8a0e0",

        "status_bar.background": "#0e0c18",
        "title_bar.background": "#0a0814",
        "title_bar.inactive_background": "#0a0814",
        "toolbar.background": "#12101e",

        "tab_bar.background": "#0a0814",
        "tab.active_background": "#12101e",
        "tab.inactive_background": "#0a0814",

        "search.match_background": "#c4b08040",

        "panel.background": "#12101e",
        "panel.focused_border": "#b8a0e0",

        "pane.focused_border": "#b8a0e0",

        "scrollbar.thumb.background": "#302c4280",
        "scrollbar.thumb.hover_background": "#302c42b0",
        "scrollbar.thumb.border": "#00000000",
        "scrollbar.track.background": "#00000000",
        "scrollbar.track.border": "#00000000",

        "editor.background": "#12101e",
        "editor.foreground": "#d8d0e4",
        "editor.gutter.background": "#12101e",
        "editor.active_line.background": "#1e1a2c",
        "editor.highlighted_line.background": "#1e1a2c",
        "editor.line_number": "#8a8498",
        "editor.active_line_number": "#b8a0e0",
        "editor.indent_guide": "#262236",
        "editor.indent_guide_active": "#302c42",
        "editor.wrap_guide": "#262236",
        "editor.invisible": "#262236",
        "editor.subheader.background": "#0e0c18",

        "link_text.hover": "#8cc0e0",

        "conflict": "#d0a0b8",
        "conflict.background": "#d0a0b820",
        "conflict.border": "#d0a0b8",

        "created": "#a0d4a8",
        "created.background": "#a0d4a820",
        "created.border": "#a0d4a8",

        "deleted": "#c49080",
        "deleted.background": "#c4908020",
        "deleted.border": "#c49080",

        "error": "#c49080",
        "error.background": "#c4908020",
        "error.border": "#c49080",

        "hidden": "#8a8498",
        "hidden.background": "#0e0c18",
        "hidden.border": "#262236",

        "hint": "#88c0b8",
        "hint.background": "#88c0b820",
        "hint.border": "#88c0b8",

        "ignored": "#8a8498",
        "ignored.background": "#0e0c18",
        "ignored.border": "#262236",

        "info": "#8cc0e0",
        "info.background": "#8cc0e020",
        "info.border": "#8cc0e0",

        "modified": "#8cc0e0",
        "modified.background": "#8cc0e020",
        "modified.border": "#8cc0e0",

        "predictive": "#8a8498",
        "predictive.background": "#1e1a2c",
        "predictive.border": "#262236",

        "renamed": "#8cc0e0",
        "renamed.background": "#8cc0e020",
        "renamed.border": "#8cc0e0",

        "success": "#a0d4a8",
        "success.background": "#a0d4a820",
        "success.border": "#a0d4a8",

        "unreachable": "#8a8498",
        "unreachable.background": "#0e0c18",
        "unreachable.border": "#262236",

        "warning": "#c4b080",
        "warning.background": "#c4b08020",
        "warning.border": "#c4b080",

