        "terminal.foreground": "#d8d0e4",
        "terminal.bright_foreground": "#d8d0e4",
        "terminal.dim_foreground": "#b0a8c4",
        "terminal.ansi.black": "#56526c",
        "terminal.ansi.red": "#c49080",
        "terminal.ansi.green": "#a0d4a8",
        "terminal.ansi.yellow": "#c4b080",
        "terminal.ansi.blue": "#8cc0e0",
        "terminal.ansi.magenta": "#b8a0e0",
        "terminal.ansi.cyan": "#88c0b8",
        "terminal.ansi.white": "#b0a8c4",
        "terminal.ansi.bright_black": "#68647e",
        "terminal.ansi.bright_red": "#d0a0b8",
        "terminal.ansi.bright_green": "#a8d4b8",
        "terminal.ansi.bright_yellow": "#e8b4a0",
        "terminal.ansi.bright_blue": "#a0c8e0",
        "terminal.ansi.bright_magenta": "#c4b0e0",
        "terminal.ansi.bright_cyan": "#a0d4cc",
        "terminal.ansi.bright_white": "#d8d0e4",

        "players": [
          { "cursor": "#d0a0b8", "background": "#d0a0b820", "selection": "#262236" },
          { "cursor": "#8cc0e0", "background": "#8cc0e020", "selection": "#262236" },
          { "cursor": "#a0d4a8", "background": "#a0d4a820", "selection": "#262236" },
          { "cursor": "#e8b4a0", "background": "#e8b4a020", "selection": "#262236" },
          { "cursor": "#b8a0e0", "background": "#b8a0e020", "selection": "#262236" },
          { "cursor": "#88c0b8", "background": "#88c0b820", "selection": "#262236" },
          { "cursor": "#c4b080", "background": "#c4b08020", "selection": "#262236" },
          { "cursor": "#c49080", "background": "#c4908020", "selection": "#262236" }
        ],

        "syntax": {
          "attribute": { "color": "#8cc0e0", "font_style": "italic" },
          "boolean": { "color": "#e8b4a0" },
          "comment": { "color": "#7e7896", "font_style": "italic" },
          "comment.doc": { "color": "#7e7896", "font_style": "italic" },
          "constant": { "color": "#e8b4a0" },
          "constructor": { "color": "#e8b4a0" },
          "emphasis": { "color": "#d0a0b8", "font_style": "italic" },
          "emphasis.strong": { "color": "#e8b4a0", "font_weight": 700 },
          "enum": { "color": "#e8b4a0" },
          "function": { "color": "#8cc0e0" },
          "keyword": { "color": "#b8a0e0", "font_style": "italic" },
          "label": { "color": "#d0a0b8" },
          "link_text": { "color": "#8cc0e0" },
          "link_uri": { "color": "#8cc0e0" },
          "namespace": { "color": "#d8d0e4" },
          "number": { "color": "#c4b080" },
          "operator": { "color": "#d0a0b8" },
          "preproc": { "color": "#88c0b8" },
          "primary": { "color": "#d8d0e4" },
          "property": { "color": "#d8d0e4" },
          "punctuation": { "color": "#8a8498" },
          "punctuation.bracket": { "color": "#8a8498" },
          "punctuation.delimiter": { "color": "#8a8498" },
          "punctuation.list_marker": { "color": "#d0a0b8" },
          "punctuation.special": { "color": "#88c0b8" },
          "string": { "color": "#a0d4a8" },
          "string.escape": { "color": "#88c0b8" },
          "string.regex": { "color": "#88c0b8" },
          "string.special": { "color": "#88c0b8" },
          "string.special.symbol": { "color": "#e8b4a0" },
          "tag": { "color": "#88c0b8" },
          "text.literal": { "color": "#a0d4a8" },
          "title": { "color": "#b8a0e0", "font_weight": 700 },
          "type": { "color": "#e8b4a0" },
          "variable": { "color": "#d8d0e4" },
          "variable.special": { "color": "#d8d0e4", "font_style": "italic" },
          "variant": { "color": "#e8b4a0" }
        }
