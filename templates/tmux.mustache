# Auto-generated from palette.json — do not edit manually
# Run `bun run generate` to regenerate
#
# {{name}} — tmux theme
# https://github.com/danfry1/theme-template

set -ga terminal-overrides ",*:RGB"

set -g status-style "bg={{backgrounds.dim}},fg={{foregrounds.subtext}}"
set -g status-left-length 40
set -g status-right-length 40
set -g status-left "#{?client_prefix,#[fg={{backgrounds.shadow}}#,bg={{accents.operator}}#,bold] PREFIX ,#[fg={{backgrounds.shadow}},bg={{accents.keyword}},bold] #{session_name} }#[fg=default,bg={{backgrounds.dim}},nobold] "
set -g status-right "#[fg={{foregrounds.overlay}}] %H:%M #[fg={{foregrounds.overlay}}]│ #[fg={{foregrounds.overlay}}]#{host_short} "

set -g window-status-format "#[fg={{foregrounds.overlay}},bg={{backgrounds.dim}}] #{window_index}:#{window_name} "
set -g window-status-current-format "#[fg={{foregrounds.text}},bg={{backgrounds.surface0}},bold] #{window_index}:#{window_name} "
set -g window-status-separator ""

set -g pane-border-style "fg={{backgrounds.surface1}}"
set -g pane-active-border-style "fg={{accents.keyword}}"

set -g mode-style "fg={{backgrounds.shadow}},bg={{accents.keyword}}"

set -g message-style "fg={{foregrounds.text}},bg={{backgrounds.surface0}}"
set -g message-command-style "fg={{foregrounds.text}},bg={{backgrounds.surface0}}"

set -g clock-mode-colour "{{accents.keyword}}"

set -g copy-mode-match-style "fg={{backgrounds.shadow}},bg={{accents.number}}"
set -g copy-mode-current-match-style "fg={{backgrounds.shadow}},bg={{accents.type}}"
