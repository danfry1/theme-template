# {{name}} ({{variant}})
[colors.primary]
foreground = "{{foregrounds.text}}"
background = "{{backgrounds.base}}"

[colors.cursor]
text = "{{backgrounds.base}}"
cursor = "{{special.cursor}}"

[colors.vi_mode_cursor]
text = "{{backgrounds.base}}"
cursor = "{{accents.keyword}}"

[colors.selection]
text = "CellForeground"
background = "{{special.selection}}"

[colors.search.matches]
foreground = "{{backgrounds.base}}"
background = "{{accents.number}}"

[colors.search.focused_match]
foreground = "{{backgrounds.base}}"
background = "{{accents.type}}"

[colors.hints.start]
foreground = "{{backgrounds.base}}"
background = "{{accents.number}}"

[colors.hints.end]
foreground = "{{backgrounds.base}}"
background = "{{accents.func}}"

[colors.footer_bar]
foreground = "{{foregrounds.text}}"
background = "{{backgrounds.dim}}"

[colors.normal]
black = "{{ansi.black}}"
red = "{{ansi.red}}"
green = "{{ansi.green}}"
yellow = "{{ansi.yellow}}"
blue = "{{ansi.blue}}"
magenta = "{{ansi.magenta}}"
cyan = "{{ansi.cyan}}"
white = "{{ansi.white}}"

[colors.bright]
black = "{{ansi.brightBlack}}"
red = "{{ansi.brightRed}}"
green = "{{ansi.brightGreen}}"
yellow = "{{ansi.brightYellow}}"
blue = "{{ansi.brightBlue}}"
magenta = "{{ansi.brightMagenta}}"
cyan = "{{ansi.brightCyan}}"
white = "{{ansi.brightWhite}}"
