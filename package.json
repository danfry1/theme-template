{
  "name": "theme-template",
  "version": "0.1.0",
  "description": "Generate terminal, editor, and CLI color themes from a single role-based palette.json",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danfry1/theme-template.git"
  },
  "homepage": "https://github.com/danfry1/theme-template",
  "bugs": {
    "url": "https://github.com/danfry1/theme-template/issues"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "generate": "bun scripts/generate.ts",
    "init-theme": "bun run scripts/init-theme.ts",
    "test": "bun test",
    "validate": "bun scripts/generate.ts --validate-only",
    "check": "bun scripts/generate.ts --check",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["color-theme", "terminal", "neovim", "tmux", "dark-theme"],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "mustache": "4.2.0"
  },
  "devDependencies": {
    "@types/mustache": "4.2.6",
    "bun-types": "1.3.14",
    "typescript": "5.9.3"
  }
}
